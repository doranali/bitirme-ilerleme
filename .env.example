# Enterprise Log Platform - Environment Variables
# Copy to .env and configure for Portainer Stack deployment

# Panel - Dev ortamında admin/admin123! ile giriş (prod'da 0 yapın)
DEV_DEFAULT_CREDENTIALS=1

# Network Configuration
NETWORK_SUBNET=172.20.0.0/16
NETWORK_GATEWAY=172.20.0.1
TZ=Europe/Istanbul

# Paths (adjust for your deployment)
# Docker Compose uses ./data/ by default; override via DATA_ROOT if needed
CERTS_PATH=./config/certs
ARSIV_LOG_PATH=./data/arsiv_loglari
OPENSEARCH_DATA1_PATH=./data/opensearch_data1
OPENSEARCH_DATA2_PATH=./data/opensearch_data2
OPENSEARCH_DATA3_PATH=./data/opensearch_data3
# setup konteyneri: OpenSearch veri dizini 1000:1000 değilse başarısız (varsayılan 1). NFS root_squash vb. için 0.
# SETUP_STRICT_OPENSEARCH_PERMS=1
KAFKA_DATA1_PATH=./data/kafka_data1
KAFKA_DATA2_PATH=./data/kafka_data2
KAFKA_DATA3_PATH=./data/kafka_data3
MONGODB_DATA_PATH=./data/mongodb_data
NGINX_PROXY_MANAGER_DATA_PATH=./data/nginx-proxy-manager/data
NGINX_PROXY_MANAGER_LETSENCRYPT_PATH=./data/nginx-proxy-manager/letsencrypt
PORTAINER_DATA_PATH=./data/portainer_data
GRAFANA_DATA_PATH=./data/grafana_data
GRAYLOG_ALERTS_PATH=./config/graylog_alerts
RCLONE_CONFIG_PATH=./src/config/common/rclone.conf

# Kafka (KRaft) — prod’da 2 bırakın. Küçük test VM / disk baskısı / tek broker ISR’da kaldıysa:
# KAFKA_MIN_INSYNC_REPLICAS=1
# KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
# Broker yeniden başlatıldıktan sonra mevcut topic’lerde hâlâ min.isr=2 ise:
# docker compose exec kafka1 kafka-configs --bootstrap-server kafka1:9092 --entity-type topics --entity-name logs_raw --alter --add-config min.insync.replicas=1

# OpenSearch Configuration (Kafka KRaft - Zookeeper kullanılmıyor)
OPENSEARCH_CLUSTER_NAME=opensearch-cluster
OPENSEARCH_VERSION=2.18.0
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CHANGE_ME
# Grafana: compose grafana servisi OPENSEARCH_* değişkenlerini geçirir; parola boşsa önce INITIAL sonra OPENSEARCH_PASSWORD kullanılır.
# Küme ilk kurulduktan sonra .env parolasını değiştirirseniz OpenSearch iç şifresi değişmez — Grafana/OpenSearch uyumsuzluğu için veri dizinini sıfırlamak veya güvenlik API ile admin şifresini güncellemek gerekir.
OPENSEARCH_TLS_SKIP_VERIFY=true
OPENSEARCH_AUTH_TYPE=basic
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=CHANGE_ME

# Sentetik trafik (flog): varsayılan kapalı. Tanım: docker-compose.synthetic-traffic.yml (prod tar paketine dahil DEĞİL).
# LOG_SYSTEM_ENV=prod iken panel bu ayarı göstermez ve log-gen başlatılamaz.
# Test: docker compose -f docker-compose.yml ... -f docker-compose.synthetic-traffic.yml --profile synthetic-traffic up -d log-gen
LOG_SYNTHETIC_GENERATOR=false

# Merkez fluent-bit → Graylog `log_env` (UDP 5151). Konteynerde tanımlı değilse start-fluent-bit.sh varsayılanı prod.
# Lab/test ayrımı (dev_test stream): fluent-bit servisine environment ile verin: LOG_SYSTEM_ENV=dev_test
#LOG_SYSTEM_ENV=prod

# Merkez Fluent Bit: kayıtta company_id yoksa bu kod basılır (Grafana `company_id` değişkeni). Tek kiracı: kurum kodu (ör. tubitak_demo).
# Çok kiracı / MSSP: her uç JSON’da company_id gönderin + Graylog pipeline ile doğrulama; log metninden otomatik çıkarım önerilmez.
#LOG_SYSTEM_COMPANY_ID=default

# Graylog Configuration
GRAYLOG_PASSWORD_SECRET=please-change-this-secret-to-a-random-value
# Web «admin» ve panel/watchdog API: düz metin. Yönetim panelinden kaydettiğinizde GRAYLOG_ROOT_PASSWORD_SHA2 otomatik eşlenir.
# graylog-post-init (GELF UDP input) bu değişkeni kullanır; Graylog UI’da parola değiştirdiyseniz .env ile aynı yapın yoksa «no running inputs» kalır.
GRAYLOG_ROOT_PASSWORD=admin
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918  # SHA256(admin); panel düz parolayı kaydedince güncellenir
GRAYLOG_PORT=9000
GRAYLOG_WEB_URL=http://localhost:9000
# Saat tutarlılığı: Graylog’da her kullanıcı Profil → Time zone → Europe/Istanbul (sunucu TZ ve GRAYLOG_ROOT_TIMEZONE ile aynı olsun).
# Journal üst sınırı — kurulum/preflight: disk-plan-for-env.sh boş alana göre ayarlar (prod.env’deki 2gb küçük diskte otomatik düşer)
# Elle sabitlemek: GRAYLOG_MESSAGE_JOURNAL_MAX_SIZE_LOCKED=1  |  Otomatik planı kapatmak: SKIP_AUTO_DISK_PLAN=1
GRAYLOG_MESSAGE_JOURNAL_MAX_SIZE=512mb
# İsteğe bağlı: panel «Auto-Tune» veya elle; boş bırakılırsa compose giriş noktası /proc üzerinden hesaplar
#GRAYLOG_JAVA_HEAP_MB=1588
#OPENSEARCH_JAVA_HEAP_MB=3176

# SMTP Configuration (Email Notifications)
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_AUTH=true
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=logs@yourdomain.com
SMTP_SUBJECT_PREFIX=[Log Platform]

# Telegram Configuration (Watchdog)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_THRESHOLD_MINUTES=5
HEALTH_CHECK_HOURS=1

# Grafana Configuration
GRAFANA_DATASOURCE_NAME=opensearch-ds
GRAFANA_INTERVAL=Daily
GRAFANA_TIMEFIELD=@timestamp
GRAFANA_MESSAGE_FIELD=message
GRAFANA_LEVEL_FIELD=level

# Nginx Proxy Manager
NPM_HTTP_PORT=80
NPM_ADMIN_PORT=81
NPM_HTTPS_PORT=443

# Portainer
PORTAINER_HTTP_PORT=9001
PORTAINER_HTTPS_PORT=9443

# MinIO Configuration (Optional S3 Storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_DEFAULT_BUCKETS=logs-backup
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_DATA_PATH=./data/minio_data

# 5651 Signing & Archiving
SIGNER_TYPE=OPEN_SOURCE  # OPEN_SOURCE or TUBITAK
ARCHIVE_DESTINATION=local  # local, s3:bucket-name, sftp:server/path, minio:bucket-name
# Üretim TSA; entegrasyon testi için Kamu SM test sunucusu adresini yalnızca staging’de kullanın (docs/5651_UYUMLULUK.md).
TUBITAK_TSA_URL=https://kamusm.bilgem.tubitak.gov.tr/tsa
# TÜBİTAK TSA HTTPS test CA / self-signed için yalnızca staging (sign_logs.sh curl -k).
# TUBITAK_TLS_INSECURE=0

# Management UI
MANAGEMENT_UI_PORT=8080
MANAGEMENT_UI_SECRET_KEY=CHANGE_ME
# Panel enrollment: Windows ajan kurulumunda indirilecek Fluent Bit zip (log-management-ui okur)
# FLUENT_BIT_WINDOWS_VERSION=5.0.2
# FLUENT_BIT_WINDOWS_ZIP_URL=https://packages.fluentbit.io/windows/fluent-bit-5.0.2-win64.zip
# Windows Olay Gunlugu kanallari (CSV). Guvenlik kanali sorun cikarsa once Application,System deneyin:
# FLUENT_BIT_WINDOWS_EVENT_CHANNELS=Application,System
# FLUENT_BIT_WINDOWS_SERVICE_NAME=LogPlatformFluentBit
# Ters vekil / split DNS: tarayıcı ve ajanların aynı panel/ingest host adını görmesi için
# LOG_PLATFORM_PUBLIC_HOST=logs.sirketiniz.local
# Tam panel URL (kurulum linkleri, Windows/Linux script MANAGEMENT_API). NPM/HTTPS arkasında önerilir:
# LOG_PLATFORM_PUBLIC_BASE_URL=https://logs.sirketiniz.local
# Sadece HOST verildiyse şema (varsayılan https):
# LOG_PLATFORM_PUBLIC_SCHEME=https
# Lab: panel HTTPS self-signed ise Windows tek satir IWR ve indirilen .ps1 icindeki panel cagrilarinda TLS dogrulamasini kapatir (uretimde acmayin).
# LOG_PLATFORM_INSECURE_TLS_FOR_AGENT_SCRIPTS=1
# Windows servis: gecikmeli otostart (bazı sunucularda SCM başlatmayı bozabiliyor; varsayılan kapalı)
# FLUENT_BIT_WINDOWS_DELAYED_START=0
# İsteğe bağlı: servisi Tcpip sürücüsüne bağımlı yap (1); sorun çıkarırsa 0 bırakın
# FLUENT_BIT_WINDOWS_SERVICE_DEPEND_TCP=0
# Disk hazırlama (panel): compose varsayılanı panel imajı + ağ kapalı — apk/DNS’te takılmayı önler
# LOG_SYSTEM_PREPARE_DISK_IMAGE=log-system/log-management-ui:${LOG_SYSTEM_RELEASE_TAG:-dev}
# İsteğe bağlı: yalnızca genişletme konteyneri için farklı imaj (resize2fs+parted gerekir; alpine kullanmayın)
# LOG_SYSTEM_GROW_DISK_IMAGE=log-system/log-management-ui:${LOG_SYSTEM_RELEASE_TAG:-dev}
# LOG_SYSTEM_PREPARE_DISK_NO_NETWORK=1
# LOG_SYSTEM_PREPARE_DISK_TIMEOUT_SEC=900
# Storage profile: veri yolu kök FS’teyse önce uyarı; panelden ikinci onay veya (otomasyon) lab:
# LOG_SYSTEM_ALLOW_STORAGE_PROFILE_ON_ROOT_DISK=1
# Tek veri VMDK kilidi: veri kökten ayrıyken panel ikinci ham disk hazırlığına izin vermez (prod varsayılan).
# İstisnai ikinci ham disk / göç: log-management-ui ortamına ekleyin:
# LOG_SYSTEM_ALLOW_EXTRA_DATA_DISK_PREPARE=1

# Setup service variables
CERT_FILE_VAR=default.crt
NEED_RENEWAL_VAR=false

# MongoDB SSL/TLS
MONGODB_TLS_CERT_FILE=mongodb.pem
MONGODB_TLS_CA_FILE=ca.crt

# Rclone Configuration (if using remote storage)
# Configure rclone.conf separately
