      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": true,
          "reducer": ["count"],
          "countRows": true,
          "fields": ""
        },
        "sortBy": [{"displayName": "Zaman", "desc": true}]
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Network / syslog (log_type:network — vendor filtresi yok)",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23}
    },
    {
      "id": 101,
      "type": "timeseries",
      "title": "Olay hacmi (syslog)",
      "description": "Seçili şirket + cihaz (source). Vendor syslog’ta çoğu kurulumda unknown/boş olduğu için bu panelde kullanılmaz.",
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "opensearch-main"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "refId": "A",
          "timeField": "timestamp",
          "query": "company_id:${company_id} AND source:${host} AND log_type:network",
          "bucketAggs": [
            {"id": "2", "type": "date_histogram", "field": "timestamp", "settings": {"interval": "5m", "min_doc_count": 0}}
          ],
          "metrics": [{"id": "1", "type": "count"}]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5000},
              {"color": "red", "value": 20000}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 102,
      "type": "table",
      "title": "Syslog gönderen (IP)",
      "description": "syslog_sender_ip terimleri. Boşsa: (1) Fluent Bit Source_Address_Key + yeniden başlatma, (2) OpenSearch’te alan tipi (text ise .keyword ile deneyin), (3) Graylog→OS çıktı alanları.",
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "opensearch-main"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {
          "refId": "A",
          "timeField": "timestamp",
          "query": "company_id:${company_id} AND source:${host} AND log_type:network",
          "bucketAggs": [
            {"id": "2", "type": "terms", "field": "syslog_sender_ip", "settings": {"size": "25", "order": "desc", "orderBy": "_count", "min_doc_count": 0}}
          ],
          "metrics": [{"id": "1", "type": "count"}]
        }
      ],
      "options": {"showHeader": true}
    },
    {
      "id": 200,
      "type": "row",
      "title": "Endpoint / ajan (Elastic ECS) — vCenter syslog bu bölümde veri üretmez",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32}
    },
    {
      "id": 201,
      "type": "timeseries",
      "title": "CPU/RAM (ajan, ECS event.dataset)",
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "opensearch-main"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "targets": [
        {
          "refId": "A",
          "timeField": "timestamp",
          "query": "company_id:${company_id} AND source:${host} AND vendor:${vendor} AND log_type:generic AND (_exists_:event.dataset) AND (event.dataset:system.cpu OR event.dataset:system.memory)",
          "bucketAggs": [
            {"id": "2", "type": "date_histogram", "field": "timestamp", "settings": {"interval": "5m", "min_doc_count": 0}}
          ],
          "metrics": [{"id": "1", "type": "count"}]
        }
      ]
    },
    {
      "id": 202,
      "type": "stat",
      "title": "Başarısız oturum (ajan, ECS)",
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "opensearch-main"
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
      "targets": [
        {
          "refId": "A",
          "timeField": "timestamp",
          "query": "company_id:${company_id} AND source:${host} AND vendor:${vendor} AND log_type:generic AND (_exists_:event.category) AND event.category:authentication AND (event.outcome:failure OR message:*failed* OR message:*invalid*)",
          "bucketAggs": [
            {"id": "2", "type": "date_histogram", "field": "timestamp", "settings": {"interval": "auto", "min_doc_count": 0}}
          ],
          "metrics": [{"id": "1", "type": "count"}]
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["sum"], "values": false},
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 50},
              {"color": "red", "value": 100}
            ]
          }
        },
        "overrides": []
      }
    }
  ]
