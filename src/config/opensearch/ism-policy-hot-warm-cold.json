{
  "policy": {
    "description": "5651 uyumlu Graylog index lifecycle: hot (7d) -> warm (23d) -> cold (700d) -> delete. Toplam 730 gün (2 yıl) retention.",
    "default_state": "hot",
    "ism_template": [
      {
        "index_patterns": ["graylog_*", "*-graylog-*"],
        "priority": 100
      }
    ],
    "states": [
      {
        "name": "hot",
        "actions": [],
        "transitions": [
          {
            "state_name": "warm",
            "conditions": {
              "min_index_age": "7d"
            }
          }
        ]
      },
      {
        "name": "warm",
        "actions": [
          {
            "replica_count": {
              "number_of_replicas": 0
            }
          },
          {
            "force_merge": {
              "max_num_segments": 1
            }
          },
          {
            "read_only": {}
          }
        ],
        "transitions": [
          {
            "state_name": "cold",
            "conditions": {
              "min_index_age": "23d"
            }
          }
        ]
      },
      {
        "name": "cold",
        "actions": [
          {
            "close": {}
          }
        ],
        "transitions": [
          {
            "state_name": "delete",
            "conditions": {
              "min_index_age": "700d"
            }
          }
        ]
      },
      {
        "name": "delete",
        "actions": [
          {
            "delete": {}
          }
        ],
        "transitions": []
      }
    ]
  }
}
