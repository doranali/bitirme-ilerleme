/config/audit/
/data/tenants.json
/data/mongodb_data/
/data/opensearch_data*/
/data/minio_data/
/data/kafka_data*/
/data/grafana_data/
/graylog_journal/
/logs/
/qa-*.json
/qa-run-*.md
/config/certs/

# Panel image/runtime leaks (bind-mount overrides in compose; keep out of git)
/src/services/log-management-ui/config/users.yaml
/src/services/log-management-ui/config/audit/events.jsonl
/src/services/log-management-ui/config/data/tenants.json

# Live syslog trust lists (panel-managed)
/src/services/fluent-bit/syslog-trusted-sources.txt
/src/services/fluent-bit/agent-trusted-sources.txt
