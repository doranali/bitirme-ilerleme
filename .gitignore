Thumbs.db
.env
envs/*.env
!envs/*.env.example
envs/test-sync.env

# Runtime / instance state (never commit)
/panel-setup-state.json
/users.yaml
/state/*.json
/state/.graylog-post-init.done
/state/audit/
/state/qa-evidence-*.json
